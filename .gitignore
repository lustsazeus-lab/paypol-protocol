# ── Dependencies ──────────────────────────────────────────
node_modules/
venv/
.venv/
__pycache__/
*.pyc
*.pyo

# ── Build outputs ─────────────────────────────────────────
dist/
build/
out/
cache/
artifacts/
typechain-types/
.next/
.turbo/

# ── Environment secrets ───────────────────────────────────
.env
.env.local
.env.production
.env.*.local
# Keep example template
!.env.example

# ── Databases (local dev only) ────────────────────────────
*.db
*.sqlite
*.sqlite3

# ── ZK ceremony files (large, download separately) ────────
packages/circuits/*.ptau
# Keep compiled circuit artifacts needed for proving
# packages/circuits/*.wasm  → tracked (needed by frontend)
# packages/circuits/*.zkey  → tracked (needed for proof generation)

# ── Logs ──────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*

# ── Claude Code ──────────────────────────────────────────
.claude/

# ── OS & IDE ──────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# ── Foundry / Hardhat ─────────────────────────────────────
cache/
out/
broadcast/*/31337/  # local anvil receipts only

# ── Prisma ────────────────────────────────────────────────
# Keep schema files, ignore generated client
# prisma/generated/

# ── Python ────────────────────────────────────────────────
*.egg-info/
.pytest_cache/
htmlcov/
.coverage
